# Supabase — maak een project op https://supabase.com en kopieer deze waarden
# uit Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Single-user toegang: enkel dit e-mailadres mag inloggen (server-side check in
# de auth-callback). Leeg laten = iedereen met een geldige sessie toelaten.
ALLOWED_EMAIL=jarno.degreve@gmail.com

# Obsidian-koppeling (optioneel) — ONRAJ schrijft je notities als .md naar een
# privé GitHub-repo, die je met de Obsidian Git-plugin in je vault synct.
# Token = fine-grained PAT met enkel deze repo + "Contents: read and write".
GITHUB_TOKEN=
GITHUB_REPO=eigenaar/onraj-notes
GITHUB_BRANCH=main
# Submap in de repo/vault waar de notities komen (standaard "ONRAJ").
GITHUB_NOTES_DIR=ONRAJ
# Twee-weg-sync: geheim van de GitHub-webhook (push-event) op de notitie-repo,
# zodat Obsidian-edits terug in ONRAJ komen. Leeg = twee-weg uit.
GITHUB_WEBHOOK_SECRET=

# Service-role key (Supabase → Project Settings → API). ZEER GEHEIM, server-only
# (omzeilt RLS). Nodig voor flows zonder sessie: Telegram-webhook + later push-cron.
SUPABASE_SERVICE_ROLE_KEY=

# Telegram-bot (optioneel) — berichten naar je bot worden automatisch taken.
# Bot-token via @BotFather; user-ID via @userinfobot; secret = willekeurige string.
TELEGRAM_BOT_TOKEN=
TELEGRAM_SECRET_TOKEN=
TELEGRAM_ALLOWED_USER_ID=

# Push-meldingen (web-push). Genereer sleutels met: npx web-push generate-vapid-keys
# De publieke sleutel mag naar de browser (NEXT_PUBLIC_), de private blijft server-only.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:jarno.degreve@gmail.com
# Geheim dat Vercel Cron meestuurt (Authorization: Bearer ...) om de cron te beveiligen.
CRON_SECRET=

# Deel-naar-ONRAJ: geheim voor de /api/share-webhook (iOS-Shortcut). De PWA
# share-target werkt via je sessie en heeft dit niet nodig.
SHARE_SECRET=

# Rooktest (Playwright) — logt in en controleert dat elke pagina rendert.
# Draaien: `npm run smoke:install` (eenmalig) en daarna `npm run smoke`.
# SMOKE_BASE_URL standaard = https://onraj.vercel.app (zet op http://localhost:3000 voor lokaal).
SMOKE_BASE_URL=
SMOKE_EMAIL=
SMOKE_PASSWORD=
